{
  "name": "gamesync",
  "version": "1.0.1",
  "description": "Windows 游戏存档同步器 - Game Save Synchronizer",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --remote-debugging-port=9222",
    "package": "electron-packager . GameSync --platform=win32 --arch=x64 --out=dist --overwrite --icon=src/renderer/assets/icon.ico --asar",
    "package:arm64": "electron-packager . GameSync --platform=win32 --arch=arm64 --out=dist --overwrite --icon=src/renderer/assets/icon.ico --asar",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "author": "GameSync",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.gamesync.app",
    "productName": "GameSync",
    "win": {
      "target": "nsis",
      "icon": "src/renderer/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "src/**/*"
    ]
  }
}
