{
  "name": "gamesync",
  "version": "1.1.3",
  "description": "Windows 游戏存档同步器 - Game Save Synchronizer",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --remote-debugging-port=9222",
    "build:win32x64": "electron-builder --win --x64",
    "build:win32arm64": "electron-builder --win --arm64",
    "build:all": "npm run build:win32x64 ; npm run build:win32arm64",
    "build:t1": "electron-builder --win --x64 --arm64",
    "pack": "electron-builder --dir"
  },
  "author": "GameSync",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.gamesync.app",
    "productName": "GameSync",
    "win": {
      "target": "nsis",
      "icon": "src/renderer/assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "src/**/*"
    ]
  }
}